# Security Suite Configuration
# Copy this file to .env and fill in your values
# All variables are prefixed with SECSUITE_

# =============================================================================
# GENERAL SETTINGS
# =============================================================================

# Enable debug mode for verbose logging
SECSUITE_DEBUG=false

# Custom data directory (default: ~/.secsuite)
# SECSUITE_DATA_DIR=/path/to/data

# Optional SecLists root directory for external wordlists
# If not set, Security Suite will try to auto-detect sibling folders like
# /path/to/Projects/SecLists-master
# SECSUITE_SECLISTS_PATH=/path/to/SecLists-master

# =============================================================================
# API KEYS - External Services
# =============================================================================

# Shodan - Internet-wide scanning data (https://shodan.io)
# Get your API key: https://account.shodan.io/
SECSUITE_SHODAN_API_KEY=

# VirusTotal - Malware analysis (https://virustotal.com)
# Get your API key: https://www.virustotal.com/gui/my-apikey
SECSUITE_VIRUSTOTAL_API_KEY=

# Hunter.io - Email discovery (https://hunter.io)
# Get your API key: https://hunter.io/api_keys
SECSUITE_HUNTER_API_KEY=

# =============================================================================
# AI PROVIDERS - Choose one or more
# =============================================================================

# Anthropic Claude (cloud) - https://console.anthropic.com/
SECSUITE_ANTHROPIC_API_KEY=

# OpenAI GPT (cloud) - https://platform.openai.com/api-keys
SECSUITE_OPENAI_API_KEY=

# For local LLMs (Ollama), no API key needed!
# Just run: ollama serve
# Then use: secsuite ai ask "question" -p llama3

# =============================================================================
# NETWORK SETTINGS
# =============================================================================

# Request timeout in seconds
SECSUITE_REQUEST_TIMEOUT=30

# Maximum concurrent requests
SECSUITE_MAX_CONCURRENT_REQUESTS=10

# Rate limiting (requests per second)
SECSUITE_REQUESTS_PER_SECOND=5.0

# Custom user agent
# SECSUITE_USER_AGENT=SecuritySuite/0.1.0
